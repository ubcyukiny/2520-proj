<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css"
    />
    <link href="/css/style.css" rel="stylesheet" />
    <title>Homepage</title>
  </head>
  <body>
    <main>
      <div class="authOptions">
        <h1><a href="/posts">Homepage</a></h1>

        <% if (!user) { %>
          <a role="button" href="/auth/login">Login</a>
        <% } else { %>
          <a role="button" href="/auth/logout">Logout</a>
          <a role="button" href="/posts/create">Create Post</a>
        <% } %>
      </div>

      <h2>Welcome, <%= user?.uname || "Visitor" %></h2>

      <div style="margin-bottom: 1rem;">
        <a href="/subs/list">View Subgroups</a>
      </div>

      <div>
        <h3>All Posts</h3>

        <% if (posts && posts.length > 0) { %>
          <% posts.forEach(post => { %>
            <div class="individualPost" style="margin-bottom: 1.5rem;">
              <a href="/posts/show/<%= post.id %>">
                <strong><%= post.title %></strong>
              </a>

              <p><%= post.description %></p>

              <small>
                Posted by 
                <%= post.creator?.uname || post.creator %> 
                |
                <%= new Date(post.timestamp).toLocaleString() %>
              </small>
            </div>
          <% }) %>
        <% } else { %>
          <p>No posts yet.</p>
        <% } %>
      </div>
    </main>
  </body>
</html>