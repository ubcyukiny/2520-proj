<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@picocss/pico@1/css/pico.classless.min.css"
    />
    <link href="/css/style.css" rel="stylesheet" />
    <title>Post</title>
  </head>
  <body>
    <main>
      <div class="authOptions">
        <h1>View Post</h1>
        <a role="button" href="/posts">Home</a>
      </div>

      <article>
        <h2><%= post.title %></h2>

        <% if (post.link) { %>
          <p>
            <a href="<%= post.link %>" target="_blank">Visit Link</a>
          </p>
        <% } %>

        <p><%= post.description %></p>

        <small>
          Posted by 
          <%= post.creator && post.creator.uname ? post.creator.uname : post.creator %>
          |
          <%= new Date(post.timestamp).toLocaleString() %>
        </small>
      </article>

      <hr />

      <section>
        <h3>Comments</h3>

        <% if (comments && comments.length > 0) { %>
          <% comments.forEach((comment) => { %>
            <div style="margin-bottom: 1rem;">
              <p><%= comment.description %></p>
              <small>
                by 
                <%= comment.creator && comment.creator.uname ? comment.creator.uname : comment.creator %>
                |
                <%= new Date(comment.timestamp).toLocaleString() %>
              </small>
            </div>
          <% }) %>
        <% } else { %>
          <p>No comments yet.</p>
        <% } %>
      </section>

      <hr />

      <% if (user) { %>
        <section>
          <h3>Add Comment</h3>
          <form action="/posts/comment-create/<%= post.id %>" method="POST">
            <textarea name="description" required></textarea>
            <button type="submit">Post Comment</button>
          </form>
        </section>
      <% } else { %>
        <p><a href="/login">Login to comment</a></p>
      <% } %>

    </main>
  </body>
</html>